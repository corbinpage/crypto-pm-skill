{
  "name": "user-feedback-synthesis",
  "version": "0.1.0",
  "private": true,
  "description": "Daily routine: pull customer feedback from configured sources, synthesize into a Notion page, and create deduplicated tickets in the Backlog DB.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx --env-file=.env src/index.ts",
    "seed": "tsx --env-file=.env scripts/seed-notes.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@notionhq/client": "^2.2.15",
    "googleapis": "^144.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
