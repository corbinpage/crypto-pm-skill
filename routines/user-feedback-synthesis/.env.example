# Anthropic
ANTHROPIC_API_KEY=

# Notion (Paymagic team space integration)
NOTION_API_KEY=
# Notion DB / page IDs are set in config.json, not here. The integration must
# be added to both the "User Feedback Synthesis" parent page and the "Backlog"
# database from Notion's Connections panel.

# Adapter: notion-notes
NOTION_NOTES_DB_ID=

# Adapter: gmail-meetings (Google Workspace OAuth)
# Use a service account with domain-wide delegation, or a long-lived OAuth
# refresh token. The PoC expects the refresh-token shape below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Email address whose Gmail + Drive will be queried. Must have access to the
# meeting transcripts the agent should ingest.
GOOGLE_USER_EMAIL=
